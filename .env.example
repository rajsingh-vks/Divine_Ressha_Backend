MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=divine_reesha
CORS_ORIGINS=http://localhost:3000
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_CURRENCY=INR

# Environment
ENVIRONMENT=development
OTP_EXPOSE_CODES=true

# Email OTP delivery: console | smtp | ses | disabled
EMAIL_DELIVERY_BACKEND=console
SES_FROM_EMAIL=
SES_CONFIGURATION_SET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# Legacy aliases also supported:
EMAIL_USER=
EMAIL_PASS=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# SMS OTP delivery: console | webhook | disabled
SMS_DELIVERY_BACKEND=console
SMS_WEBHOOK_URL=
SMS_WEBHOOK_AUTH_TOKEN=
