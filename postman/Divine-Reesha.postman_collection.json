    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register customer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@example.com\",\n  \"password\": \"Password@123\",\n  \"full_name\": \"Customer User\",\n  \"role\": \"customer\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "const json = pm.response.json();",
                    "if (json?.tokens?.access_token) pm.environment.set('accessToken', json.tokens.access_token);",
                    "if (json?.tokens?.refresh_token) pm.environment.set('refreshToken', json.tokens.refresh_token);",
                    "if (json?.user?.id) pm.environment.set('userId', json.user.id);"
                  ],
                  "type": "text/javascript"
                }
              }
            ]
          }
        },
